{
  "name": "@accordproject/ui-concerto",
  "version": "0.98.0",
  "private": false,
  "dependencies": {
    "@accordproject/concerto-core": "^3.25.7",
    "@accordproject/concerto-util": "^3.25.7",
    "@babel/runtime": "^7.10.3",
    "lodash.get": "^4.4.2",
    "lodash.isequal": "^4.5.0",
    "lodash.set": "^4.3.2",
    "lodash.topath": "^4.5.2",
    "prop-types": "^15.7.2",
    "react": "^16.13.1",
    "react-dom": "^16.13.1",
    "semantic-ui-calendar-react": "^0.15.3",
    "semantic-ui-react": "^2.1.5"
  },
  "scripts": {
    "test": "jest",
    "build": "npx rollup -c --sourcemap",
    "build:watch": "npx rollup -c --sourcemap -w",
    "build:prod": "npx rollup -c",
    "fix:js": "npx eslint --fix ./src/",
    "lint:js": "npx eslint ./src/",
    "lint:style": "npx stylelint ./src/",
    "fix:style": "npx stylelint ./src/ --fix",
    "start:docs": "docz dev",
    "build:docs": "docz build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/accordproject/web-components",
    "directory": "packages/ui-concerto"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "main": "lib/index.cjs.js",
  "module": "lib/index.esm.js",
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "pre-push": "CI=true yarn test --passWithNoTests"
    }
  },
  "devDependencies": {
    "@babel/cli": "^7.24.0",
    "@babel/core": "^7.24.0",
    "@babel/plugin-transform-runtime": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "@rollup/plugin-babel": "5.0.4",
    "@rollup/plugin-commonjs": "12.0.0",
    "@rollup/plugin-node-resolve": "8.1.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^15.0.0",
    "@testing-library/react-hooks": "3.2.1",
    "@testing-library/user-event": "^14.5.0",
    "autoprefixer": "9.7.6",
    "babel-jest": "^29.0.0",
    "docz": "2.3.1",
    "husky": "4.2.5",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "lint-staged": "10.1.7",
    "npm-run-all": "4.1.5",
    "postcss-preset-env": "6.7.0",
    "prop-types": "^15.7.2",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "recursive-copy": "2.0.10",
    "rimraf": "3.0.2",
    "rollup": "2.7.3",
    "rollup-plugin-eslint": "7.0.0",
    "rollup-plugin-filesize": "7.0.0",
    "rollup-plugin-includepaths": "0.2.3",
    "rollup-plugin-node-builtins": "2.1.2",
    "rollup-plugin-peer-deps-external": "2.2.2",
    "rollup-plugin-postcss": "3.1.1",
    "rollup-plugin-stylelint": "1.0.0",
    "rollup-plugin-terser": "5.3.0",
    "stylelint": "13.3.3",
    "stylelint-config-standard": "20.0.0",
    "stylelint-order": "4.0.0"
  },
  "peerDependencies": {
    "react": ">=16.13.1",
    "react-dom": ">=16.13.1"
  },
  "files": [
    "lib"
  ],
  "engines": {
    "node": ">=18"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "transform": {
      "^.+\\.(js|jsx)$": "babel-jest"
    },
    "setupFilesAfterEnvironment": ["@testing-library/jest-dom"],
    "moduleNameMapper": {
      "^react-dom/client$": "<rootDir>/node_modules/react-dom/client.js",
      "^react-dom$": "<rootDir>/node_modules/react-dom/index.js",
      "\\.(css|less)$": "<rootDir>/test/__mocks__/styleMock.js"
    },
    "testEnvironmentOptions": {
      "customExportConditions": ["node", "node-addons"]
    }
  }
}
